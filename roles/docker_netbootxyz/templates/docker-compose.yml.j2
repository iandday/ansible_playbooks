# {{ ansible_managed }}

services:
  netbootxyz:
    image: ghcr.io/netbootxyz/netbootxyz
    container_name: netbootxyz
    restart: unless-stopped
    volumes:
      - {{ docker_netbootxyz_docker_storage }}/netbootxyz_config:/config
      - {{ docker_netbootxyz_assets_path }}:/assets
    environment:
      - MENU_VERSION=3.0.2
      - NGINX_PORT=80
      - WEB_APP_PORT=3000
      - PUID={{ docker_uid }}
      - PGID={{ docker_gid }}   
    network_mode: host
