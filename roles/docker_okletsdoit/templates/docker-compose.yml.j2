# {{ ansible_managed }}

services:
  okletsdoit-postgres:
    image: postgres:17.4
    container_name: okletsdoit-postgres
    volumes:
      - {{ docker_okletsdoit_docker_storage }}/okletsdoit_db:/var/lib/postgresql/data
    environment:
      - POSTGRES_USER={{ vault_docker_okletsdoit_db_username }}
      - POSTGRES_PASSWORD={{ vault_docker_okletsdoit_db_password }}
      - POSTGRES_DB=wedding
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ vault_docker_okletsdoit_db_username }}"]
      interval: 30s
      timeout: 10s
      retries: 5
    restart: unless-stopped
    labels:
      - "traefik.enable=false"
  okletsdoit-redis:
    image: redis:7.0
    container_name: okletsdoit-redis
    command: [ "redis-server", "--save", "60", "1", "--loglevel", "warning" ]
    volumes:
      - {{ docker_okletsdoit_docker_storage }}/okletsdoit_redis:/data
    healthcheck:
      test: [ "CMD", "redis-cli", "ping" ]
      interval: 30s
      timeout: 10s
      retries: 5
    restart: unless-stopped
  okletsdoit-frontend:
    image: ghcr.io/iandday/okletsdoit-frontend:latest
    container_name: okletsdoit-frontend
    restart: always
    environment:
      - BACKEND_API_URL=http://okletsdoit-app:8000
      - PUBLIC_CLIENT_API_URL=https://aboutdayumtime.com
      - SERVICE_TOKEN={{ vault_docker_okletsdoit_api_backend_token }}
      - VITE_ALLOWED_HOSTS=aboutdayumtime.com
      - BODY_SIZE_LIMIT=1G  
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network=traefik_proxy"
      - "traefik.http.routers.okletsdoit-frontend-secure.entrypoints=web-secure"
      - "traefik.http.routers.okletsdoit-frontend-secure.rule=Host(`aboutdayumtime.com`) || Host(`www.aboutdayumtime.com`)"
      - "traefik.http.routers.okletsdoit-frontend-secure.priority=10"
      - "traefik.http.routers.okletsdoit-frontend-secure.tls=true"
      - "traefik.http.routers.okletsdoit-frontend-secure.tls.certresolver=route53"
      - "traefik.http.routers.okletsdoit-frontend-secure.tls.domains[0].main=aboutdayumtime.com"
      - "traefik.http.routers.okletsdoit-frontend-secure.tls.domains[0].sans=*.aboutdayumtime.com"
      - "traefik.http.services.okletsdoit-frontend-secure.loadbalancer.server.port=3000"
      - "traefik.http.routers.okletsdoit-frontend-secure.middlewares=file-upload@file"
    networks:
      - traefik_proxy
      - default
  okletsdoit-app:
    image: ghcr.io/iandday/okletsdoit-backend:latest
    container_name: okletsdoit-app
    restart: always
    environment:
      - POSTGRES_USER={{ vault_docker_okletsdoit_db_username }}
      - POSTGRES_PASSWORD={{ vault_docker_okletsdoit_db_password }}
      - POSTGRES_DB=wedding
      - POSTGRES_HOST=okletsdoit-postgres
      - POSTGRES_PORT=5432
      - SECRET_KEY={{ vault_docker_okletsdoit_secret_key }}
      - DEBUG=False
      - DJANGO_LOG_LEVEL=INFO
      - ALLOWED_HOSTS={{ vault_docker_okletsdoit_allowed_hosts }}
      - TIMEZONE=America/New_York
      - DJANGO_SUPERUSER_EMAIL={{ vault_docker_okletsdoit_admin_email }}
      - DJANGO_SUPERUSER_PASSWORD={{ vault_docker_okletsdoit_admin_password }}
      - AUTHENTIK_URL={{ vault_docker_wedding_auth_url }}
      - AUTHENTIK_CLIENT_ID={{ vault_docker_wedding_auth_client_id }}
      - AUTHENTIK_CLIENT_SECRET={{ vault_docker_wedding_auth_client_secret }}
      - DJANGO_CSRF_TRUSTED_ORIGINS={{ vault_docker_okletsdoit_csrf_trusted_origins }}
      - DJANGO_CORS_ALLOWED_ORIGINS={{ vault_docker_okletsdoit_cors_allowed_origins }}
      - AWS_ACCESS_KEY_ID={{ vault_docker_okletsdoit_aws_access_key_id }}
      - AWS_SECRET_ACCESS_KEY={{ vault_docker_okletsdoit_aws_secret_access_key }}
      - AWS_STATIC_BUCKET_NAME={{ vault_docker_okletsdoit_aws_static_bucket_name }}
      - AWS_MEDIA_BUCKET_NAME={{ vault_docker_okletsdoit_aws_media_bucket_name }}
      - AWS_S3_REGION_NAME={{ vault_docker_okletsdoit_aws_s3_region_name }}
      - AWS_S3_ENDPOINT_URL={{ vault_docker_okletsdoit_aws_s3_endpoint_url }}
      - AWS_S3_STATIC_DOMAIN={{ vault_docker_okletsdoit_aws_s3_static_domain }}
      - AWS_S3_MEDIA_DOMAIN={{ vault_docker_okletsdoit_aws_s3_media_domain }}
      - AWS_S3_STATIC_DOMAIN_CSP={{ vault_docker_okletsdoit_aws_s3_static_domain_csp }}
      - CONTAINER_ROLE=server
      - LOCAL_DB=True
      - LOCAL_DEV=False
      - REDIS_URL=redis://okletsdoit-redis:6379
      - SERVICE_TOKEN={{ vault_docker_okletsdoit_api_backend_token }}
      - EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
      - EMAIL_HOST={{ vault_docker_utility_authentik_email_server }}
      - EMAIL_USE_TLS=True
      - EMAIL_PORT=587
      - EMAIL_HOST_USER={{ vault_docker_utility_authentik_email_username }}
      - EMAIL_HOST_PASSWORD={{ vault_docker_utility_authentik_email_password }}
      - EMAIL_URL_BASE=https://aboutdayumtime.com
      - PERSONALIZED_RSVP_BASE_URL=https://aboutdayumtime.com
      - RSVP_URL=https://aboutdayumtime.com/rsvp
    networks:
      - traefik_proxy
      - default
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network=traefik_proxy"
      - "traefik.http.routers.okletsdoit-secure.entrypoints=web-secure"
      - "traefik.http.routers.okletsdoit-secure.rule=Host(`aboutdayumtime.com`) || Host(`www.aboutdayumtime.com`) && (PathPrefix(`/be_admin`) || PathPrefix(`/static`) || PathPrefix(`/media`) || PathPrefix(`/api`) || PathPrefix(`/accounts`) || PathPrefix(`/_allauth`))"
      - "traefik.http.routers.okletsdoit-secure.priority=35"
      - "traefik.http.routers.okletsdoit-secure.tls=true"
      - "traefik.http.routers.okletsdoit-secure.tls.certresolver=route53"
      - "traefik.http.routers.okletsdoit-secure.tls.domains[0].main=aboutdayumtime.com"
      - "traefik.http.routers.okletsdoit-secure.tls.domains[0].sans=*.aboutdayumtime.com"
      - "traefik.http.services.okletsdoit-secure.loadbalancer.server.port=8000"
      - "traefik.http.routers.okletsdoit-secure.middlewares=file-upload@file"
    depends_on:
      - okletsdoit-postgres
  okletsdoit-worker:
    image: ghcr.io/iandday/okletsdoit-backend:latest
    container_name: okletsdoit-worker
    restart: always
    environment:
      - POSTGRES_USER={{ vault_docker_okletsdoit_db_username }}
      - POSTGRES_PASSWORD={{ vault_docker_okletsdoit_db_password }}
      - POSTGRES_DB=wedding
      - POSTGRES_HOST=okletsdoit-postgres
      - POSTGRES_PORT=5432
      - SECRET_KEY={{ vault_docker_okletsdoit_secret_key }}
      - DEBUG=False
      - DJANGO_LOG_LEVEL=INFO
      - ALLOWED_HOSTS={{ vault_docker_okletsdoit_allowed_hosts }}
      - TIMEZONE=America/New_York
      - DJANGO_SUPERUSER_EMAIL={{ vault_docker_okletsdoit_admin_email }}
      - DJANGO_SUPERUSER_PASSWORD={{ vault_docker_okletsdoit_admin_password }}
      - AUTHENTIK_URL={{ vault_docker_wedding_auth_url }}
      - AUTHENTIK_CLIENT_ID={{ vault_docker_wedding_auth_client_id }}
      - AUTHENTIK_CLIENT_SECRET={{ vault_docker_wedding_auth_client_secret }}
      - DJANGO_CSRF_TRUSTED_ORIGINS={{ vault_docker_okletsdoit_csrf_trusted_origins }}
      - DJANGO_CORS_ALLOWED_ORIGINS={{ vault_docker_okletsdoit_cors_allowed_origins }}
      - AWS_ACCESS_KEY_ID={{ vault_docker_okletsdoit_aws_access_key_id }}
      - AWS_SECRET_ACCESS_KEY={{ vault_docker_okletsdoit_aws_secret_access_key }}
      - AWS_STATIC_BUCKET_NAME={{ vault_docker_okletsdoit_aws_static_bucket_name }}
      - AWS_MEDIA_BUCKET_NAME={{ vault_docker_okletsdoit_aws_media_bucket_name }}
      - AWS_S3_REGION_NAME={{ vault_docker_okletsdoit_aws_s3_region_name }}
      - AWS_S3_ENDPOINT_URL={{ vault_docker_okletsdoit_aws_s3_endpoint_url }}
      - AWS_S3_STATIC_DOMAIN={{ vault_docker_okletsdoit_aws_s3_static_domain }}
      - AWS_S3_MEDIA_DOMAIN={{ vault_docker_okletsdoit_aws_s3_media_domain }}
      - AWS_S3_STATIC_DOMAIN_CSP={{ vault_docker_okletsdoit_aws_s3_static_domain_csp }}
      - CONTAINER_ROLE=worker
      - LOCAL_DB=True
      - LOCAL_DEV=False
      - REDIS_URL=redis://okletsdoit-redis:6379
      - SERVICE_TOKEN={{ vault_docker_okletsdoit_api_backend_token }}
      - EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
      - EMAIL_HOST={{ vault_docker_utility_authentik_email_server }}
      - EMAIL_USE_TLS=True
      - EMAIL_PORT=587
      - EMAIL_HOST_USER={{ vault_docker_utility_authentik_email_username }}
      - EMAIL_HOST_PASSWORD={{ vault_docker_utility_authentik_email_password }}
      - EMAIL_URL_BASE=https://aboutdayumtime.com
      - PERSONALIZED_RSVP_BASE_URL=https://aboutdayumtime.com
      - RSVP_URL=https://aboutdayumtime.com/rsvp
    labels:
      - "traefik.enable=false"
    depends_on:
      - okletsdoit-postgres
  okletsdoit-beats:
    image: ghcr.io/iandday/okletsdoit-backend:latest
    container_name: okletsdoit-beats
    restart: always
    environment:
      - POSTGRES_USER={{ vault_docker_okletsdoit_db_username }}
      - POSTGRES_PASSWORD={{ vault_docker_okletsdoit_db_password }}
      - POSTGRES_DB=wedding
      - POSTGRES_HOST=okletsdoit-postgres
      - POSTGRES_PORT=5432
      - SECRET_KEY={{ vault_docker_okletsdoit_secret_key }}
      - DEBUG=False
      - DJANGO_LOG_LEVEL=INFO
      - ALLOWED_HOSTS={{ vault_docker_okletsdoit_allowed_hosts }}
      - TIMEZONE=America/New_York
      - DJANGO_SUPERUSER_EMAIL={{ vault_docker_okletsdoit_admin_email }}
      - DJANGO_SUPERUSER_PASSWORD={{ vault_docker_okletsdoit_admin_password }}
      - AUTHENTIK_URL={{ vault_docker_wedding_auth_url }}
      - AUTHENTIK_CLIENT_ID={{ vault_docker_wedding_auth_client_id }}
      - AUTHENTIK_CLIENT_SECRET={{ vault_docker_wedding_auth_client_secret }}
      - DJANGO_CSRF_TRUSTED_ORIGINS={{ vault_docker_okletsdoit_csrf_trusted_origins }}
      - DJANGO_CORS_ALLOWED_ORIGINS={{ vault_docker_okletsdoit_cors_allowed_origins }}
      - AWS_ACCESS_KEY_ID={{ vault_docker_okletsdoit_aws_access_key_id }}
      - AWS_SECRET_ACCESS_KEY={{ vault_docker_okletsdoit_aws_secret_access_key }}
      - AWS_STATIC_BUCKET_NAME={{ vault_docker_okletsdoit_aws_static_bucket_name }}
      - AWS_MEDIA_BUCKET_NAME={{ vault_docker_okletsdoit_aws_media_bucket_name }}
      - AWS_S3_REGION_NAME={{ vault_docker_okletsdoit_aws_s3_region_name }}
      - AWS_S3_ENDPOINT_URL={{ vault_docker_okletsdoit_aws_s3_endpoint_url }}
      - AWS_S3_STATIC_DOMAIN={{ vault_docker_okletsdoit_aws_s3_static_domain }}
      - AWS_S3_MEDIA_DOMAIN={{ vault_docker_okletsdoit_aws_s3_media_domain }}
      - AWS_S3_STATIC_DOMAIN_CSP={{ vault_docker_okletsdoit_aws_s3_static_domain_csp }}
      - CONTAINER_ROLE=beats
      - LOCAL_DB=True
      - LOCAL_DEV=False
      - REDIS_URL=redis://okletsdoit-redis:6379
      - SERVICE_TOKEN={{ vault_docker_okletsdoit_api_backend_token }}
      - EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
      - EMAIL_HOST={{ vault_docker_utility_authentik_email_server }}
      - EMAIL_USE_TLS=True
      - EMAIL_PORT=587
      - EMAIL_HOST_USER={{ vault_docker_utility_authentik_email_username }}
      - EMAIL_HOST_PASSWORD={{ vault_docker_utility_authentik_email_password }}
      - EMAIL_URL_BASE=https://aboutdayumtime.com
      - PERSONALIZED_RSVP_BASE_URL=https://aboutdayumtime.com
      - RSVP_URL=https://aboutdayumtime.com/rsvp
    labels:
      - "traefik.enable=false"
    depends_on:
      - okletsdoit-postgres
  
networks:
  traefik_proxy:
      name: traefik_proxy
      external: true
  default:
    driver: bridge
