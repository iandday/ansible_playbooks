    plants-https:
      rule: "Host(`plants.{{ all_ext_domain }}`)"
      entryPoints:
        - web-secure
      service: plants-service
      tls:
        certresolver: route53
        domains:
          - main: "{{ all_ext_domain }}"
            sans:
              - "*.{{ all_ext_domain }}"
    hortusfox-https:
      rule: "Host(`plant.{{ all_ext_domain }}`)"
      entryPoints:
        - web-secure
      service: hortusfox-service
      tls:
        certresolver: route53
        domains:
          - main: "{{ all_ext_domain }}"
            sans:
              - "*.{{ all_ext_domain }}"
    okletsdoit-backend-https:
      rule: "HostRegexp(`(?:www.)?aboutdayumtime.com`) && (PathPrefix(`/be_admin`) || PathPrefix(`/static`) || PathPrefix(`/media`) || PathPrefix(`/api`) || PathPrefix(`/accounts`) || PathPrefix(`/_allauth`))"
      priority: 35
      entryPoints:
        - web-secure
      middlewares:
        - file-upload
      service: okletsdoit-backend-service
      tls:
        certresolver: route53
        domains:
          - main: "aboutdayumtime.com"
            sans:
              - "*.aboutdayumtime.com"
    okletsdoit-frontend-https:
      rule: "HostRegexp(`(?:www.)?aboutdayumtime.com`)"
      priority: 10
      entryPoints:
        - web-secure
      middlewares:
        - file-upload
      service: okletsdoit-frontend-service
      tls:
        certresolver: route53
        domains:
          - main: "aboutdayumtime.com"
            sans:
              - "*.aboutdayumtime.com"
    homebox-https:
      rule: "Host(`stuff.{{ all_ext_domain }}`)"
      entryPoints:
        - web-secure
      service: homebox-service
      tls:
        certresolver: route53
        domains:
          - main: "{{ all_ext_domain }}"
            sans:
              - "*.{{ all_ext_domain }}"
  services:
    media-service:
      loadBalancer:
        servers:
          - url: http://10.168.1.15:32400/web
    hass-service:
      loadBalancer:
        servers:
          - url: http://10.168.1.14:8123
    overseerr-service:
