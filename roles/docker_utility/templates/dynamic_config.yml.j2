---
# {{ ansible_managed }}
tls:
  options:
    mtls-client-auth: 
      clientAuth:
        caFiles:
          - "/etc/traefik/root-ca.crt"
        clientAuthType: RequireAndVerifyClientCert 
http:
  middlewares:
    authentik:
      forwardAuth:
        address: "http://authentik_server:9000/outpost.goauthentik.io/auth/traefik"
        trustForwardHeader: true
        authResponseHeaders:
          - X-Authentik-Username
          - X-Authentik-Groups
          - X-Authentik-Email
          - X-Authentik-Name
          - X-Authentik-Uid
          - X-Authentik-Jwt
          - X-Authentik-Meta-Jwks
          - X-Authentik-Meta-Outpost
          - X-Authentik-Meta-Provider
          - X-Authentik-Meta-App
          - X-Authentik-Meta-Version
    file-upload:
      buffering:
        maxRequestBodyBytes: 1073741824 
        memRequestBodyBytes: 107374182 
  routers:
    cctv-https:
      rule: "Host(`cctv.{{ all_ext_domain }}`)"
      entryPoints:
        - web-secure
      middlewares:
        - authentik
      service: cctv-service

      tls:
        certresolver: route53
        domains:
          - main: "{{ all_ext_domain }}"
            sans:
              - "*.{{ all_ext_domain }}"
    media-https:
      rule: "Host(`media.{{ all_ext_domain }}`)"
      entryPoints:
        - web-secure
      service: media-service
      tls:
        certresolver: route53
        domains:
          - main: "{{ all_ext_domain }}"
            sans:
              - "*.{{ all_ext_domain }}"
    hass-https:
      rule: "Host(`hass.{{ all_ext_domain }}`)"
      entryPoints:
        - web-secure
      service: hass-service
      tls:
        certresolver: route53
        domains:
          - main: "{{ all_ext_domain }}"
            sans:
              - "*.{{ all_ext_domain }}"
    overseerr-https:
      rule: "Host(`requests.{{ all_ext_domain }}`)"
      entryPoints:
        - web-secure
      service: overseerr-service
      tls:
        certresolver: route53
        domains:
          - main: "{{ all_ext_domain }}"
            sans:
              - "*.{{ all_ext_domain }}"
