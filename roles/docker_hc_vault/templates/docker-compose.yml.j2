# {{ ansible_managed }}

services:
  hcv_1:
    image: hashicorp/vault:{{ docker_hc_vault_version }}
    container_name: hcv_1
    restart: unless-stopped
    cap_add:
      - IPC_LOCK    
    command: vault server -config=/vault/config/vault.hcl
    environment:
      - VAULT_ADDR=https://127.0.0.1:8200
      - VAULT_CACERT=/vault/config/root-ca.crt
    volumes:
      - {{ docker_hc_vault_docker_storage }}/hc_vault_1/config:/vault/config
      - {{ docker_hc_vault_docker_storage }}/hc_vault_1/data:/vault/data
      - {{ docker_hc_vault_docker_storage }}/hc_vault_1/config/cert.crt:/opt/vault/tls/vault-cert.pem 
      - {{ docker_hc_vault_docker_storage }}/hc_vault_1/config/cert.key:/opt/vault/tls/vault-key.pem
      - {{ docker_hc_vault_docker_storage }}/hc_vault_1/config/root-ca.crt:/opt/vault/tls/vault-ca.pem
    networks:
      - traefik_proxy
      - hc_vault
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network=traefik_proxy"
      - "traefik.http.services.hc-vault.loadbalancer.server.port=8200"
      - "traefik.http.services.hc-vault.loadbalancer.server.scheme=https"
      - "traefik.http.services.hc-vault.loadbalancer.server.insecureSkipVerify=true"
      - "traefik.http.routers.hc-vault.service=hc-vault"
      - "traefik.http.routers.hc-vault.entrypoints=web-secure"
      - "traefik.http.routers.hc-vault.rule=Host(`hc_vault.{{ all_ext_domain }}`)"
      - "traefik.http.routers.hc-vault.tls=true"
      - "traefik.http.routers.hc-vault.tls.certresolver=route53"
      - "traefik.http.routers.hc-vault.tls.domains[0].main={{ all_ext_domain }}"
      - "traefik.http.routers.hc-vault.tls.domains[0].sans=*.{{ all_ext_domain }}"
    healthcheck:
      test: ["CMD", "vault", "status"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 15s
    deploy:
      resources:
        limits:
          cpus: '1'
          memory: 1G
  hcv_2:
    image: hashicorp/vault:{{ docker_hc_vault_version }}
    container_name: hcv_2
    restart: unless-stopped
    cap_add:
      - IPC_LOCK    
    command: vault server -config=/vault/config/vault.hcl
    environment:
      - VAULT_ADDR=https://127.0.0.1:8200
      - VAULT_CACERT=/vault/config/root-ca.crt
    volumes:
      - {{ docker_hc_vault_docker_storage }}/hc_vault_2/data:/vault/data
      - {{ docker_hc_vault_docker_storage }}/hc_vault_2/config:/vault/config
      - {{ docker_hc_vault_docker_storage }}/hc_vault_2/config/cert.crt:/opt/vault/tls/vault-cert.pem 
      - {{ docker_hc_vault_docker_storage }}/hc_vault_2/config/cert.key:/opt/vault/tls/vault-key.pem
      - {{ docker_hc_vault_docker_storage }}/hc_vault_2/config/root-ca.crt:/opt/vault/tls/vault-ca.pem
    networks:
      - traefik_proxy
      - hc_vault
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network=traefik_proxy"
      - "traefik.http.services.hc-vault.loadbalancer.server.port=8200"
      - "traefik.http.services.hc-vault.loadbalancer.server.scheme=https"
      - "traefik.http.services.hc-vault.loadbalancer.server.insecureSkipVerify=true"
      - "traefik.http.routers.hc-vault.service=hc-vault"
      - "traefik.http.routers.hc-vault.entrypoints=web-secure"
      - "traefik.http.routers.hc-vault.rule=Host(`hc_vault.{{ all_ext_domain }}`)"
      - "traefik.http.routers.hc-vault.tls=true"
      - "traefik.http.routers.hc-vault.tls.certresolver=route53"
      - "traefik.http.routers.hc-vault.tls.domains[0].main={{ all_ext_domain }}"
      - "traefik.http.routers.hc-vault.tls.domains[0].sans=*.{{ all_ext_domain }}"
    healthcheck:
      test: ["CMD", "vault", "status"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 15s
    deploy:
      resources:
        limits:
          cpus: '1'
          memory: 1G
  hcv_3:
    image: hashicorp/vault:{{ docker_hc_vault_version }}
    container_name: hcv_3
    restart: unless-stopped
    cap_add:
      - IPC_LOCK    
    command: vault server -config=/vault/config/vault.hcl
    environment:
      - VAULT_ADDR=https://127.0.0.1:8200
      - VAULT_CACERT=/vault/config/root-ca.crt
    volumes:
      - {{ docker_hc_vault_docker_storage }}/hc_vault_3/data:/vault/data
      - {{ docker_hc_vault_docker_storage }}/hc_vault_3/config:/vault/config
      - {{ docker_hc_vault_docker_storage }}/hc_vault_3/config/cert.crt:/opt/vault/tls/vault-cert.pem 
      - {{ docker_hc_vault_docker_storage }}/hc_vault_3/config/cert.key:/opt/vault/tls/vault-key.pem
      - {{ docker_hc_vault_docker_storage }}/hc_vault_3/config/root-ca.crt:/opt/vault/tls/vault-ca.pem
    networks:
      - traefik_proxy
      - hc_vault
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network=traefik_proxy"
      - "traefik.http.services.hc-vault.loadbalancer.server.port=8200"
      - "traefik.http.services.hc-vault.loadbalancer.server.scheme=https"
      - "traefik.http.services.hc-vault.loadbalancer.server.insecureSkipVerify=true"
      - "traefik.http.routers.hc-vault.service=hc-vault"
      - "traefik.http.routers.hc-vault.entrypoints=web-secure"
      - "traefik.http.routers.hc-vault.rule=Host(`hc_vault.{{ all_ext_domain }}`)"
      - "traefik.http.routers.hc-vault.tls=true"
      - "traefik.http.routers.hc-vault.tls.certresolver=route53"
      - "traefik.http.routers.hc-vault.tls.domains[0].main={{ all_ext_domain }}"
      - "traefik.http.routers.hc-vault.tls.domains[0].sans=*.{{ all_ext_domain }}"
    healthcheck:
      test: ["CMD", "vault", "status"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 15s
    deploy:
      resources:
        limits:
          cpus: '1'
          memory: 1G
  vault-unsealer:
    image: hashicorp/vault:{{ docker_hc_vault_version }}
    container_name: vault-unsealer
    restart: unless-stopped
    volumes:
      - ./auto-unseal-monitor.sh:/usr/local/bin/auto-unseal-monitor.sh:ro
      - {{ docker_hc_vault_docker_storage }}/hc_vault_1/config:/vault/config:ro
      - {{ docker_hc_vault_docker_storage }}/hc_vault_2/config:/vault/config-2:ro
      - {{ docker_hc_vault_docker_storage }}/hc_vault_3/config:/vault/config-3:ro
    entrypoint: sh /usr/local/bin/auto-unseal-monitor.sh
    environment:
      - VAULT_ADDR=https://127.0.0.1:8200
      - VAULT_CACERT=/vault/config/root-ca.crt
    depends_on:
      - hcv_3
      - hcv_2
      - hcv_1
    networks:
      - hc_vault
    deploy:
      resources:
        limits:
          cpus: '0.25'
          memory: 256M

networks:
  traefik_proxy:
    external: true
    name: traefik_proxy
  hc_vault:
    driver: bridge
    name: hc_vault

