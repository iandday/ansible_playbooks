version: "3"

vars:
  VAULT_ADDR: "https://hc-vault.{{ all_ext_domain }}"
  KEY_SHARES: 5
  KEY_THRESHOLD: 3

tasks:
  bootstrap:
    desc: Full bootstrap - start cluster, initialize, and setup
    preconditions:
      - sh: command -v jq >/dev/null 2>&1
        msg: "jq is required but not installed. Please install jq to proceed."
    cmds:
      - docker compose up -d hcv_1
      - docker compose up -d hcv_2
      - docker compose up -d hcv_3
      - echo "⏳ Waiting for containers to be ready (15 seconds)..."
      - sleep 15
      - ./init-and-generate-unseal.sh
      - docker compose up -d
      - echo ""
      - echo "📋 Credentials saved! Review them above."
      - echo "✅ Bootstrap complete!"

  reset:
    desc: Stop and remove all Vault containers, and clean up data
    cmds:
      - docker compose down -v
      - rm -rf {{ docker_hc_vault_docker_storage }}/hc_vault_1/* {{ docker_hc_vault_docker_storage }}/hc_vault_2/* {{ docker_hc_vault_docker_storage }}/hc_vault_3/*
      - rm -rf vault-credentials*.md
      - echo "All Vault data has been removed. You can now run 'task bootstrap' to start fresh."